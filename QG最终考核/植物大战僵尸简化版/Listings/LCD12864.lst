 117   2                      case 3: x|=0x98;break;//第4行地址+x的偏移
 118   2              }
 119   1              LCD12864_Write_Cmd(x,1);
 120   1              while(*str!='\0')
 121   1              {
 122   2                      LCD12864_Write_Data(*str);
 123   2                      str++;          
 124   2              }       
 125   1      } 
