 149          //图形显示128*64
 150          void LCD12864_Show_Image (unsigned char code *DData)
 151          {
 152   1              unsigned char x,y,i;
 153   1              unsigned int tmp=0;
 154   1              
 155   1              LCD12864_Write_Cmd(0x34,1);  // 关闭绘图显示，进入指令模式
 156   1          LCD12864_Write_Cmd(0x36,1);  // 打开绘图模式
 157   1              
 158   1              for(i=0;i<9;){          //分两屏，上半屏和下半屏，因为起始地址不同，需要分开
 159   2                      for(x=0;x<32;x++){                              //32行
 160   3                              LCD12864_Write_Cmd((0x80+x),1);//列地址
 161   3                              LCD12864_Write_Cmd((0x80+i),1); //行地址，下半屏，即第三行地址0X88      
 162   3                              for(y=0;y<16;y++)
 163   3                              {
 164   4                                      LCD12864_Write_Data(DData[tmp+y]);//读取数据写入LCD
 165   4                              }
 166   3                              tmp+=16;                
 167   3                      }
 168   2                      i+=8;
 169   2              }
 170   1              LCD12864_Write_Cmd(0x36,1);     //扩充功能设定
 171   1              LCD12864_Write_Cmd(0x30,1);
 172   1      }
