 106          void LCD12864_Show_String(unsigned char x,unsigned char y,unsigned char *str)
 107          {
 108   1              if(y<=0)y=0;
 109   1              if(y>3)y=3;
 110   1              x&=0x0f;        //限制x,y不能大于显示范围
 111   1      
 112   1              switch(y)
 113   1              {
 114   2                      case 0: x|=0x80;break;//第1行地址+x的偏移
 115   2                      case 1: x|=0x90;break;//第2行地址+x的偏移
 116   2                      case 2: x|=0x88;break;//第3行地址+x的偏移
