  22          //写指令
  23          void LCD12864_Write_Cmd(unsigned char cmd,BuysC)
  24          {
  25   1              if (BuysC) LCD12864_Check_Status(); //根据需要检测忙 
  26   1              LCD12864_RS=0;//选择命令
  27   1              LCD12864_WR=0;//选择写
  28   1              LCD12864_DATAPORT=cmd;//准备命令
  29   1              Delay_10us(1);
  30   1              LCD12864_E=1;
  31   1              LCD12864_E=1;
  32   1              LCD12864_E=1;//使能脚E先上升沿写入
  33   1              LCD12864_E=0;//使能脚E后负跳变完成写入
  34   1      }
  35          
  36          //写数据
  37          void LCD12864_Write_Data(unsigned char dat)
  38          {
  39   1              LCD12864_Check_Status(); //检测忙
  40   1              LCD12864_RS=1;//选择数据
  41   1              LCD12864_WR=0;//选择写
  42   1              LCD12864_DATAPORT=dat;//准备数据
  43   1              Delay_10us(1);
  44   1              LCD12864_E=1;
  45   1              LCD12864_E=1;
  46   1              LCD12864_E=1;//使能脚E先上升沿写入
  47   1              LCD12864_E=0;//使能脚E后负跳变完成写入
  48   1      }
  49          
  50          //读状态
  51          unsigned char LCD12864_Check_Status(void)
  52          {
  53   1               LCD12864_DATAPORT = 0xFF; 
  54   1               LCD12864_RS = 0;
C51 COMPILER V9.54   LCD12864                                                              04/16/2026 00:57:03 PAGE 2   

  55   1               LCD12864_WR = 1; 
  56   1               LCD12864_E = 1;
