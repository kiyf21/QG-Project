 124          void LCD12864_Show_String(unsigned char x,unsigned char y,unsigned char *str)
 125          {
 126   1              if(y<=0)y=0;
 127   1              if(y>3)y=3;
 128   1              x&=0x0f;        //限制x,y不能大于显示范围
 129   1      
 130   1              switch(y)
 131   1              {
 132   2                      case 0: x|=0x80;break;//第1行地址+x的偏移
 133   2                      case 1: x|=0x90;break;//第2行地址+x的偏移
 134   2                      case 2: x|=0x88;break;//第3行地址+x的偏移
 135   2                      case 3: x|=0x98;break;//第4行地址+x的偏移
 136   2              }
 137   1              LCD12864_Write_Cmd(x,1);
 138   1              while(*str!='\0')
 139   1              {
 140   2                      LCD12864_Write_Data(*str);
 141   2                      str++;          
 142   2              }       
 143   1      } 
