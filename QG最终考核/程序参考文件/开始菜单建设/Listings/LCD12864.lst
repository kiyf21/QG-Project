  65          //LCD初始化
  66          void LCD12864_Init(void)
  67          {
  68   1              //LCD12864_PSB=1;//选择8位或4位并口方式
  69   1              LCD12864_Write_Cmd(0x30,1);//数据总线8位，基本指令操作
  70   1              LCD12864_Write_Cmd(0x01,1);
  71   1              LCD12864_Write_Cmd(0x06,1);//写入新数据后光标右移，显示屏不移动
  72   1              LCD12864_Write_Cmd(0x0c,1);
  73   1      }
  74          //LCD清屏
  75          void LCD12864_Clear(void)
  76          {
  77   1              LCD12864_Write_Cmd(0x01,1);     
  78   1              LCD12864_Write_Cmd(0x34,1);     
  79   1              LCD12864_Write_Cmd(0x30,1);     
  80   1      } 
  81          //LCD写入位置，用于显示位置变化的字符
  82          void LCD12864_Set_Location(unsigned char x, unsigned char y)
  83          {
  84   1              unsigned char addr;                                                             //光标RAM地址
  85   1              
  86   1              switch (y)
  87   1              {
  88   2                      case 0: addr = 0x80 + x; break;         //设置光标在屏幕第一行x位置汉字位
  89   2                      case 1: addr = 0x90 + x; break;         //设置光标在屏幕第二行x位置汉字位
  90   2                      case 2: addr = 0x88 + x; break;         //设置光标在屏幕第三行x位置汉字位
  91   2                      case 3: addr = 0x98 + x; break;         //设置光标在屏幕第四行x位置汉字位
  92   2                      default: break;
  93   2              }
  94   1              LCD12864_Write_Cmd(addr,1);                             //将光标RAM地址作为指令写入液晶 
  95   1              Delay_10us(10);                                                 //延时
  96   1      }
  97          
  98          //LCD闪烁
  99          void LCD_Flash(void)    //闪烁效果
 100          {
 101   1               LCD12864_Write_Cmd(0x08,1); //显示清屏
 102   1               Delay_ms(400);
 103   1               LCD12864_Write_Cmd(0x0c,1); // 显示开及光标设置
 104   1               Delay_ms(400);
 105   1               LCD12864_Write_Cmd(0x08,1); //显示清屏
 106   1               Delay_ms(400);
 107   1               LCD12864_Write_Cmd(0x0c,1); // 显示开及光标设置
 108   1               Delay_ms(400);
 109   1               LCD12864_Write_Cmd(0x08,1); //显示清屏
 110   1               Delay_ms(400);
 111   1      }
