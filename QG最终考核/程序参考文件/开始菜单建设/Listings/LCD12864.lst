  25          //写指令
  26          void LCD12864_Write_Cmd(unsigned char cmd,BuysC)
  27          {
  28   1              if (BuysC) LCD12864_Check_Status(); //根据需要检测忙 
  29   1              LCD12864_RS=0;//选择命令
  30   1              LCD12864_WR=0;//选择写
  31   1              LCD12864_DATAPORT=cmd;//准备命令
  32   1              Delay_10us(1);
  33   1              LCD12864_E=1;
  34   1              LCD12864_E=1;
  35   1              LCD12864_E=1;//使能脚E先上升沿写入
  36   1              LCD12864_E=0;//使能脚E后负跳变完成写入
  37   1      }
  38          
  39          //写数据
  40          void LCD12864_Write_Data(unsigned char dat)
  41          {
  42   1              LCD12864_Check_Status(); //检测忙
  43   1              LCD12864_RS=1;//选择数据
  44   1              LCD12864_WR=0;//选择写
  45   1              LCD12864_DATAPORT=dat;//准备数据
  46   1              Delay_10us(1);
  47   1              LCD12864_E=1;
  48   1              LCD12864_E=1;
  49   1              LCD12864_E=1;//使能脚E先上升沿写入
  50   1              LCD12864_E=0;//使能脚E后负跳变完成写入
  51   1      }
  52          
  53          //读状态
  54          unsigned char LCD12864_Check_Status(void)
C51 COMPILER V9.54   LCD12864                                                              04/10/2026 09:26:42 PAGE 2   

  55          {
  56   1               LCD12864_DATAPORT = 0xFF; 
  57   1               LCD12864_RS = 0;
  58   1               LCD12864_WR = 1; 
  59   1               LCD12864_E = 1;
  60   1               while (LCD12864_DATAPORT & Busy); //检测忙信号
  61   1               LCD12864_E = 0;
  62   1               return(LCD12864_DATAPORT);
  63   1      }
