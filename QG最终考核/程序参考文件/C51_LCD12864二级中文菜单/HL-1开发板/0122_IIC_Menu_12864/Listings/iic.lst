  89          | 返回值        :| u8 dat       -由从机读到到的一个字节数据
  90          /***********************************************************/
  91          u8 iic_read_byte()
  92          {
  93   1              u8 dat = 0;                                                             //经实测，这里必须赋初值0，否则数据会错误
  94   1              u8 mark;
  95   1              
  96   1              SDA = 1;                                                                //先释放数据总线，以便从机往总线放入数据
  97   1              for (mark=0x80; mark!=0; mark>>=1)
  98   1              {
  99   2                      iic_delay5us();                                         //延时          
 100   2                      SCL = 1;                                                        //拉高时钟总线，准备读取数据
 101   2                      iic_delay5us();                                         //延时
 102   2                      if (SDA)                                                        //如果此时数据总线是1
 103   2                      {
 104   3                              dat |= mark;                                    //将dat对应mark的高电平位置1
 105   3                      }
 106   2                      SCL = 0;                                                        //最后拉低时钟总线，结束一个字节数据的读取              
 107   2              }
 108   1              
 109   1              
 110   1              return dat;                                                             //返回读取的一个字节数据
 111   1      }
