  41          /***********************************************************|
  42          | 名称  :| 向IIC总线发送一个字节的数据等待并处理从机应答
  43          | 参数  :| u8 dat       -待发送的一个字节数据
  44          | 返回值        :| bit 0/1      -0从机应签 ，1从机未应答
  45          /***********************************************************/
  46          bit iic_write_byte(u8 dat)
  47          {
  48   1              u8 cnt = 100;                           //应答等待最大时间计数
  49   1              u8 mark;
  50   1      
  51   1              //发送一个字节数据------------------------      
  52   1              SCL = 0;                                                                //拉低时钟总线，准备数据        
  53   1              for (mark=0x80; mark!=0; mark>>=1)
  54   1              {
C51 COMPILER V9.59.0.0   IIC                                                               02/07/2021 10:51:44 PAGE 2   

  55   2                      if ((dat & mark) != 0)
  56   2                      {
  57   3                              SDA = 1;
  58   3                      }
  59   2                      else
  60   2                      {
  61   3                              SDA = 0;
  62   3                      }
  63   2                      SCL = 1;                                                        //拉高时钟总线
  64   2                      iic_delay5us();                                         //延时
  65   2                      SCL = 0;                                                        //拉低时钟总线，结束一个周期
  66   2              }
  67   1              
  68   1              //等待并处理从机应答----------------------
  69   1              SDA = 1;                                                                //释放数据总线，以便从机应答    
  70   1              do {
  71   2                              iic_delay5us();                                 //延时
  72   2                              SCL = 1;                                                //拉高时钟总线，开始应答周期
  73   2                              iic_delay5us();                                 //延时
  74   2                              if (SDA == 0)                                   //如果收到从机应答
  75   2                              {
  76   3                                      SCL = 0;                                        //结束应答周期
  77   3                                      return 0;                                       //返回0
  78   3                              }
  79   2                              SCL = 0;                                                //如果未收到从机应答，也结束应答周期
  80   2                      } while (cnt--);                                        //循环检测从机应答，直到等待最大时间到达，退出
  81   1                      
  82   1                      return 1;                                                       //等待应答最大时间过后，依然未收到应答，返回1   
  83   1      }
