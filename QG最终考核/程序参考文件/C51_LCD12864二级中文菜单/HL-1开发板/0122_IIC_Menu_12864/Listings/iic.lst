 117          | 返回值        :| 无
 118          /***********************************************************/
 119          void iic_master_ackOrNack(bit ack)
 120          {
 121   1              SCL = 0;                                        //拉低时钟总线
 122   1              SDA = ~ack;                                     //发送应答或非应答信号
 123   1              SCL = 1;                                        //拉高时钟总线
 124   1              iic_delay5us();                         //延时
 125   1              SCL = 0;                                        //拉低时钟总线，结束产生应答周期
 126   1      }


