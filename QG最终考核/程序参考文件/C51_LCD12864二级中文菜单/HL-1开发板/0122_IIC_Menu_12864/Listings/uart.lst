  15          /***********************************************************/
  16          void uart_init(u16 band)
  17          {
  18   1              TH1 = 256 - (11059200/12/32/band);              //计算band波特率下定时器1的重载值
  19   1              TL1 = TH1;                                                              //定时器1装初值
  20   1              
  21   1              TMOD = TMOD & 0x0F | 0x20;                              //保持定时器0设置不变，配置定时器1工作模式2(8位自动重载)
  22   1              SCON = 0x50;                                                    //配置串口通信模式2，使能接收数据
  23   1              ET1 = 0;                                                                //禁用定时器1中断
  24   1              ES = 1;                                                                 //打开uart中断
  25   1              TR1 = 1;                                                                //启动定时器1
  26   1      }
