  55   2                      case 0x28: down_key();          flag_keyAc = 1; break;          //单击【下】下翻菜单标题/递减设置数据
  56   2                      case 0x58: down_keyHold();      flag_keyAc = 1; break;          //持续按下【下】
  57   2                      case 0x25: leftKey();           flag_keyAc = 1; break;          //设置项左移
  58   2                      case 0x27: rightKey();          flag_keyAc = 1; break;          //设置项右移
  59   2                      case 0x0D: enter_menu2();       flag_keyAc = 1; break;          //单击【ENTER】进入二级菜单/确认并保存当前设置数据
  60   2                      case 0x2D: enter_set();         flag_keyAc = 1; break;          //长按【ENTER】进入设置
  61   2                      case 0x1B: return_menu();       flag_keyAc = 1; break;          //返回上级菜单
  62   2                      case 0x3B: exit_set();          flag_keyAc = 1; break;          //长按【ESC】退出设置
