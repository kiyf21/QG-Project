 121          /***********************************************************|
 122          | 名称  :| 将一个字节在屏幕指定位置以十六进制显示
 123          | 参数1 :| u8 x         -光标在屏幕横向位置(0-7共8个汉字位置)
 124          | 参数2 :| u8 y         -光标在屏幕纵向位置(0-3共4个汉字位置)
 125          | 参数3 :| u8 byte      -要显示的一个字节数据
 126          | 返回值        :| 无
 127          /***********************************************************/
 128          void showHex_byte(u8 x, u8 y, u8 byte)
 129          {
 130   1              u8 buf[3];
 131   1              
 132   1              //时高4位转字符------------------------------------|
 133   1              if ((byte >> 4) <= 9)
 134   1              {
 135   2                      buf[0] = (byte >> 4) + '0';                                             //高4位转字符0-9
 136   2              }
 137   1              else
 138   1              {
 139   2                      buf[0] = ((byte >> 4) - 10) + 'A';                              //高4位转字符A-F
 140   2              }
 141   1              
 142   1              //时低4位转字符------------------------------------|
 143   1              if ((byte & 0x0F) <= 9)
 144   1              {
 145   2                      buf[1] = (byte & 0x0F) + '0';                                   //低4位转字符0-9
 146   2              }
 147   1              else
 148   1              {
 149   2                      buf[1] = ((byte & 0x0F) - 10) + 'A';                    //低4位转字符A-F
 150   2              }
 151   1      
 152   1              buf[2] = '\0';                                                                          //添加结束符
 153   1              lcd12864_show_str(x, y, buf);                                           //在屏幕指定位置显示该十六进制数
 154   1      }
