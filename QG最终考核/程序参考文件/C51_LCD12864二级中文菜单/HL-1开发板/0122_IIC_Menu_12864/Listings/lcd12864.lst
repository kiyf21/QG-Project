  90          | 返回值        :| 无
  91          /***********************************************************/
  92          void lcd12864_show_str(u8 x, u8 y, u8 *str)
  93          {
  94   1              //由起始DDRAM地址连续写入字符串
  95   1              lcd12864_write_cmd(0x30);                               //启动DDRAM操作
  96   1              lcd12864_set_cursor(x, y);                              //指定显示字符串的屏幕位置      
  97   1              while (*str != '\0')                                    //检测到写入的字符是结束符\0时，结束写入
  98   1              {
  99   2                      lcd12864_write_dat(*str++);                     //连续往液晶写入字符
 100   2              }
 101   1      }
