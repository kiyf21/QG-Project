 188   2                      lcd12864_write_cmd(0x80 | xt);          //往液晶写入待写图像水平位址
 189   2                      for (xi=0; xi<w; xi++)
 190   2                      {
 191   3                              lcd12864_write_dat(img[i++]);   //连续写入一个字节的图像数据
 192   3                      }
 193   2              }
 194   1      }
