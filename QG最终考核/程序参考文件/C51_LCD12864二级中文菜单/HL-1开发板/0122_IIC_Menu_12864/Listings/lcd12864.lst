 165          | 返回值        :| 无
 166          | 备  注        :| x与w必须是16的整数倍,因CGRAM最小寻址单位为2字节,y与h可为0-63的任意值。
 167          /***********************************************************/
 168          void lcd12864_show_img(u8 x, u8 y, u8 w, u8 h, u8 *img)
 169          {
 170   1              u16 i = 0;                                                              //图像数据字节个数索引
 171   1              u8 xi;                                                                  //图像数据横向循环索引变量
 172   1              u8 yi;                                                                  //图像像素纵向循环索引变量
 173   1              u8 xt;                                                                  //图像GDRAM水平位址(0-F)
 174   1              u8 yt;                                                                  //图像GDRAM垂直位址(0-31)
 175   1              
 176   1              w >>= 3;                                                                //图像宽度/8,就是图像横向数据个数
 177   1              lcd12864_write_cmd(0x36);                               //启动GDRAM操作 
 178   1              for (yi=0; yi<h; yi++)                                  //循环图像垂直位址(每次一个像素)
C51 COMPILER V9.59.0.0   LCD12864                                                          02/10/2021 18:05:44 PAGE 4   

 179   1              {
 180   2                      yt = y*16 + yi;                                         //计算图像垂直位址(绘图模式垂直位址以位为单位)
 181   2                      xt = x;                                                         //计算图像水平位址(绘图模式水平位址以字节为单位)
 182   2                      if (yt >= 32)                                           //当图像垂直位址大于31时，应该到下半屏了
 183   2                      {
