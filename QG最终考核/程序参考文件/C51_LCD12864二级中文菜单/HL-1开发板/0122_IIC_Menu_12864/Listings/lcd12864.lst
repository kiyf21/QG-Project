 202          | 参数4 :| u8 h         - 图像高度(以1个像素点为一个单位)
 203          | 参数5 :| bit wb       - 图像反白标记，1反白显示，0正常显示
 204          | 返回值        :| 无
 205          | 备  注        :| x与w必须是16的整数倍,因CGRAM最小寻址单位为2字节,y与h可为0-63的任意值。
 206          /***********************************************************/
 207          void lcd12864_clear_area(u8 x, u8 y, u8 w, u8 h, bit wb)
 208          {
 209   1              u8 xi;                                                                  //图像数据横向循环索引变量
 210   1              u8 yi;                                                                  //图像像素纵向循环索引变量
 211   1              u8 xt;                                                                  //图像GDRAM水平位址(0-F)
 212   1              u8 yt;                                                                  //图像GDRAM垂直位址(0-31)
 213   1              
 214   1              w >>= 3;                                                                //图像宽度/8,就是图像横向数据个数
 215   1              lcd12864_write_cmd(0x36);                               //启动GDRAM操作
 216   1              for (yi=0; yi<h; yi++)                                  //循环图像垂直位址(每次一个像素)
 217   1              {
 218   2                      yt = y*16 + yi;                                         //计算图像垂直位址(绘图模式垂直位址以位为单位)
 219   2                      xt = x;                                                         //计算图像水平位址(绘图模式水平位址以字节为单位)
 220   2                      if (yt >= 32)                                           //当图像垂直位址大于31时，应该到下半屏了
 221   2                      {
 222   3                              yt -= 32;                                               //图像垂直位址减掉32(绘图模式垂直位址范围0-31)
 223   3                              xt += 8;                                                //图像水平位址+8(绘图模式水平位址0-F，其中8-F是下半屏)
 224   3                      }
 225   2                      lcd12864_write_cmd(0x80 | yt);          //往液晶写入待写图像垂直位址(这个要先写，否则显示错乱)
 226   2                      lcd12864_write_cmd(0x80 | xt);          //往液晶写入待写图像水平位址
 227   2                      for (xi=0; xi<w; xi++)
 228   2                      {
 229   3                              if (wb)
 230   3                              {
 231   4                                      lcd12864_write_dat(0xFF);       //向屏幕区域写入反白清屏数据
 232   4                              }
 233   3                              else
 234   3                              {
 235   4                                      lcd12864_write_dat(0x00);       //向屏幕区域写入正常清屏数据
 236   4                              }
 237   3                      }
 238   2              }
 239   1      }
