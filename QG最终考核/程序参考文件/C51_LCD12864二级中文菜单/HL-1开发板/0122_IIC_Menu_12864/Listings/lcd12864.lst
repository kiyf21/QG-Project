 321          /***********************************************************/
 322          void showDec_byte(u8 x, u8 y, u8 dat)
 323          {
 324   1              u8 buf[3];
 325   1              
 326   1              buf[0] = dat / 10 + '0';                //将数据对10取模+字符0放入数组第一个元素
 327   1              buf[1] = dat % 10 + '0';                //将数据对10取余+字符0存入数组第二个元素
