  62          /***********************************************************|
  63          | 名称  :| 设置光标在液晶屏幕的位置
  64          | 参数1 :| u8 x -光标在屏幕横向位置(以16个像素点为一个单位)
  65          | 参数2 :| u8 y -光标在屏幕纵向位置(以16个像素点为一个单位)
  66          | 返回值        :| 无
  67          /***********************************************************/
  68          void lcd12864_set_cursor(u8 x, u8 y)
  69          {
  70   1              u8 addr;                                                                //光标RAM地址
  71   1              
  72   1              switch (y)
  73   1              {
  74   2                      case 0: addr = 0x80 + x; break;         //设置光标在屏幕第一行x位置汉字位
  75   2                      case 1: addr = 0x90 + x; break;         //设置光标在屏幕第二行x位置汉字位
  76   2                      case 2: addr = 0x88 + x; break;         //设置光标在屏幕第三行x位置汉字位
  77   2                      case 3: addr = 0x98 + x; break;         //设置光标在屏幕第四行x位置汉字位
  78   2                      default: break;
  79   2              }
  80   1              lcd12864_write_cmd(addr);                               //将光标RAM地址作为指令写入液晶 
  81   1              delay100us();                                                   //延时
  82   1      }
