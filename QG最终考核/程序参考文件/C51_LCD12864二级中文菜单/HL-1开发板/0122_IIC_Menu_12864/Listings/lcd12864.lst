   8          /***********************************************************|
   9          | 名称  :| 检测液晶是否忙，等待液晶准备好
  10          | 参数  :| 无
  11          | 返回值        :| 无
  12          /***********************************************************/
  13          void lcd12864_wait_ready()
  14          {
  15   1              u8 sta;                                         //液晶数据口状态
  16   1              
  17   1              DB = 0xFF;                                      //这句一定要记住不能少啊，否则液晶不显示内容
  18   1              RS = 0;                                         //选择指令
  19   1              RW = 1;                                         //选择读取
  20   1              do {
  21   2                      E = 1;                                  //打开液晶使能端
  22   2                      sta = DB;                               //读取液晶数据并保存
  23   2                      E = 0;                                  //关闭液晶使能端
  24   2              } while (sta & 0x80);           //判断读取的液晶数据bit7位是否为1(忙)，循环检测直到为0(不忙)为止
  25   1      }
  26          
  27          
  28          /***********************************************************|
  29          | 名称  :| 往液晶写入一个字节的指令
  30          | 参数  :| u8 cmd       -待写指令
  31          | 返回值        :| 无
  32          /***********************************************************/
  33          void lcd12864_write_cmd(u8 cmd)
  34          {
  35   1              lcd12864_wait_ready();                  //等待液晶准备好
  36   1              RS = 0;                                                 //选择指令
  37   1              RW = 0;                                                 //选择写入
  38   1              E  = 1;                                                 //打开液晶使能端
  39   1              DB = cmd;                                               //将待写指令送到液晶数据口，等待写入
  40   1              E  = 0;                                                 //关闭液晶使能端，指令在下降沿时写入液晶
  41   1              delay100us();                                   //延时
  42   1      }
  43          
  44          
  45          /***********************************************************|
  46          | 名称  :| 往液晶写入一个字节的数据
  47          | 参数  :| u8 cmd       -待写数据
  48          | 返回值        :| 无
  49          /***********************************************************/
  50          void lcd12864_write_dat(u8 dat)
  51          {
  52   1              lcd12864_wait_ready();                  //等待液晶准备好
  53   1              RS = 1;                                                 //选择数据
  54   1              RW = 0;                                                 //选择写入
C51 COMPILER V9.59.0.0   LCD12864                                                          02/10/2021 18:05:44 PAGE 2   

  55   1              E  = 1;                                                 //打开液晶使能端
  56   1              DB = dat;                                               //将待写数据送到液晶数据口，等待写入
  57   1              E  = 0;                                                 //关闭液晶使能端，数据在下降沿时写入液晶
  58   1              delay100us();                                   //延时
  59   1      }
