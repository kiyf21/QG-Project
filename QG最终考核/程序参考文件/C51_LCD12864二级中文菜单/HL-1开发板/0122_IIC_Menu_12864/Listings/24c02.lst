  26          /***********************************************************|
  27          | 描述  :| 字节写操作向24c02写入一个字节数据
  28          | 参数1 :| u8 addr1     -24C02器件地址
  29          | 参数2 :| u8 addr2     -24C02内部存储单元地址
  30          | 参数3 :| u8 dat       -要往24C02存储的一个字节数据
  31          | 返回值        :| 无
  32          /***********************************************************/
  33          void iic_Write_dat(u8 addr1, u8 addr2, u8 dat)
  34          {
  35   1              bit ack = 0;
  36   1              
  37   1              iic_start();                                                            //产生起始信号
  38   1              
  39   1              ack = iic_write_byte(addr1);                            //寻址24c02
  40   1              if (ack)                                                                        //如果24C02未应答
  41   1                      goto lable;                                                             //就跳转
  42   1              
  43   1              ack = iic_write_byte(addr2);                            //访问24C02内部存储单元
  44   1              if (ack)                                                                        //如果24C02未应答
  45   1                      goto lable;                                                             //就跳转
  46   1              
  47   1              ack = iic_write_byte(dat);                                      //向24C02内部单元写入数据
  48   1              if (ack)                                                                        //如果24C02未应答
  49   1                      goto lable;                                                             //就跳转
  50   1              
  51   1              lable:                                                                          //跳转标签
  52   1              iic_stop();                                                                     //发送停止信号
  53   1              if (ack)                                                                        //如果24C02未应答
  54   1              {
C51 COMPILER V9.59.0.0   24C02                                                             02/07/2021 11:24:21 PAGE 2   

  55   2                      lcd12864_show_str(0,0, "写");                   //在Lcd12864屏幕第3行输出提示信息
  56   2                      lcd12864_show_str(7,0, "!!");                   //在Lcd12864屏幕第4行输出提示信息
  57   2              }
  58   1              delay10ms();                                                            //延时10ms
  59   1      }  
