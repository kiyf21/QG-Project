  12          /***********************************************************/
  13          void delay10ms()                //@11.0592MHz
  14          {
  15   1              unsigned char i, j;
  16   1      
  17   1              i = 18;
  18   1              j = 235;
  19   1              do
  20   1              {
  21   2                      while (--j);
