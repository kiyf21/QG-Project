  66          //LCD初始化
  67          void LCD12864_Init(void)
  68          {
  69   1              //LCD12864_PSB=1;//选择8位或4位并口方式
  70   1              LCD12864_Write_Cmd(0x30,1);//数据总线8位，基本指令操作
  71   1              LCD12864_Write_Cmd(0x01,1);
  72   1              LCD12864_Write_Cmd(0x06,1);//写入新数据后光标右移，显示屏不移动
  73   1              LCD12864_Write_Cmd(0x0c,1);
  74   1      }
  75          //LCD清屏
  76          void LCD12864_Clear(void)
  77          {
  78   1              LCD12864_Write_Cmd(0x01,1);     
  79   1              LCD12864_Write_Cmd(0x34,1);     
  80   1              LCD12864_Write_Cmd(0x30,1);     
  81   1      } 
  82          //LCD写入位置，用于显示位置变化的字符
  83          void LCD12864_Set_Location(unsigned char x, unsigned char y)
  84          {
  85   1              unsigned char addr;                                                             //光标RAM地址
  86   1              
  87   1              switch (y)
  88   1              {
  89   2                      case 0: addr = 0x80 + x; break;         //设置光标在屏幕第一行x位置汉字位
  90   2                      case 1: addr = 0x90 + x; break;         //设置光标在屏幕第二行x位置汉字位
  91   2                      case 2: addr = 0x88 + x; break;         //设置光标在屏幕第三行x位置汉字位
  92   2                      case 3: addr = 0x98 + x; break;         //设置光标在屏幕第四行x位置汉字位
  93   2                      default: break;
  94   2              }
  95   1              LCD12864_Write_Cmd(addr,1);                             //将光标RAM地址作为指令写入液晶 
  96   1              Delay_10us(10);                                                 //延时
  97   1      }
  98          
  99          //LCD闪烁
 100          void LCD_Flash(void)    //闪烁效果
 101          {
 102   1               LCD12864_Write_Cmd(0x08,1); //显示清屏
 103   1               Delay_ms(400);
 104   1               LCD12864_Write_Cmd(0x0c,1); // 显示开及光标设置
 105   1               Delay_ms(400);
 106   1               LCD12864_Write_Cmd(0x08,1); //显示清屏
 107   1               Delay_ms(400);
 108   1               LCD12864_Write_Cmd(0x0c,1); // 显示开及光标设置
 109   1               Delay_ms(400);
 110   1               LCD12864_Write_Cmd(0x08,1); //显示清屏
 111   1               Delay_ms(400);
 112   1      }
