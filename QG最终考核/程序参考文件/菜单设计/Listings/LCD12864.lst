 181   3                              for(y=0;y<16;y++)
 182   3                              {
 183   4                                      LCD12864_Write_Data(DData[tmp+y]);//读取数据写入LCD
 184   4                              }
 185   3                              tmp+=16;                
 186   3                      }
 187   2                      i+=8;
 188   2              }
 189   1              LCD12864_Write_Cmd(0x36,1);     //扩充功能设定
 190   1              LCD12864_Write_Cmd(0x30,1);
 191   1      }
