 168          //图形显示128*64
 169          void LCD12864_Show_Image (unsigned char code *DData)
 170          {
 171   1              unsigned char x,y,i;
 172   1              unsigned int tmp=0;
 173   1              
 174   1              LCD12864_Write_Cmd(0x34,1);  // 关闭绘图显示，进入指令模式
 175   1          LCD12864_Write_Cmd(0x36,1);  // 打开绘图模式
 176   1              
 177   1              for(i=0;i<9;){          //分两屏，上半屏和下半屏，因为起始地址不同，需要分开
 178   2                      for(x=0;x<32;x++){                              //32行
