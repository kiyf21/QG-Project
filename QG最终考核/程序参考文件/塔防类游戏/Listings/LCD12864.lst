 153          //图形显示128*64
 154          void LCD12864_Show_Image (unsigned char code *DData)
 155          {
 156   1              unsigned char x,y,i;
 157   1              unsigned int tmp=0;
 158   1              
 159   1              LCD12864_Write_Cmd(0x34,1);  // 关闭绘图显示，进入指令模式
 160   1          LCD12864_Write_Cmd(0x36,1);  // 打开绘图模式
 161   1              
 162   1              for(i=0;i<9;){          //分两屏，上半屏和下半屏，因为起始地址不同，需要分开
 163   2                      for(x=0;x<32;x++){                              //32行
 164   3                              LCD12864_Write_Cmd((0x80+x),1);//列地址
 165   3                              LCD12864_Write_Cmd((0x80+i),1); //行地址，下半屏，即第三行地址0X88      
 166   3                              for(y=0;y<16;y++)
 167   3                              {
 168   4                                      LCD12864_Write_Data(DData[tmp+y]);//读取数据写入LCD
 169   4                              }
 170   3                              tmp+=16;                
 171   3                      }
 172   2                      i+=8;
 173   2              }
 174   1              LCD12864_Write_Cmd(0x36,1);     //扩充功能设定
 175   1              LCD12864_Write_Cmd(0x30,1);
 176   1      }
