 110          void LCD12864_Show_String(unsigned char x,unsigned char y,unsigned char *str)
 111          {
 112   1              if(y<=0)y=0;
 113   1              if(y>3)y=3;
 114   1              x&=0x0f;        //限制x,y不能大于显示范围
 115   1      
 116   1              switch(y)
C51 COMPILER V9.54   LCD12864                                                              04/09/2026 00:35:59 PAGE 3   

 117   1              {
 118   2                      case 0: x|=0x80;break;//第1行地址+x的偏移
 119   2                      case 1: x|=0x90;break;//第2行地址+x的偏移
 120   2                      case 2: x|=0x88;break;//第3行地址+x的偏移
 121   2                      case 3: x|=0x98;break;//第4行地址+x的偏移
 122   2              }
 123   1              LCD12864_Write_Cmd(x,1);
 124   1              while(*str!='\0')
 125   1              {
 126   2                      LCD12864_Write_Data(*str);
 127   2                      str++;          
 128   2              }       
 129   1      } 
