 135          //按指定位置显示一个字符
 136          void LCD12864_Show_Onechar(unsigned char x, unsigned char y, unsigned char DData)
 137          {
 138   1              if(y<=0)y=0;
 139   1              if(y>3)y=3;
 140   1              x&=0x0f;        //限制x,y不能大于显示范围
 141   1      
 142   1              switch(y)
 143   1              {
 144   2                      case 0: x|=0x80;break;//第1行地址+x的偏移
 145   2                      case 1: x|=0x90;break;//第2行地址+x的偏移
 146   2                      case 2: x|=0x88;break;//第3行地址+x的偏移
 147   2                      case 3: x|=0x98;break;//第4行地址+x的偏移
 148   2              }
 149   1              LCD12864_Write_Cmd(x,0); //这里不检测忙信号，发送地址码
 150   1              LCD12864_Write_Data(DData);
 151   1      }
