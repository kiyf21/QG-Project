  66          //LCD初始化
  67          void LCD12864_Init(void)
  68          {
  69   1              //LCD12864_PSB=1;//选择8位或4位并口方式
  70   1              LCD12864_Write_Cmd(0x30,1);//数据总线8位，基本指令操作
  71   1              LCD12864_Write_Cmd(0x01,1);
  72   1              LCD12864_Write_Cmd(0x06,1);//写入新数据后光标右移，显示屏不移动
  73   1              LCD12864_Write_Cmd(0x0c,1);
  74   1      }
  75          //LCD清屏
  76          void LCD12864_Clear(void)
  77          {
  78   1              LCD12864_Write_Cmd(0x01,1);     
  79   1              LCD12864_Write_Cmd(0x34,1);     
  80   1              LCD12864_Write_Cmd(0x30,1);     
  81   1      } 
  82          
