  84          //LCD闪烁
  85          void LCD_Flash(void)    //闪烁效果
  86          {
  87   1               LCD12864_Write_Cmd(0x08,1); //显示清屏
  88   1               Delay_ms(400);
  89   1               LCD12864_Write_Cmd(0x0c,1); // 显示开及光标设置
  90   1               Delay_ms(400);
