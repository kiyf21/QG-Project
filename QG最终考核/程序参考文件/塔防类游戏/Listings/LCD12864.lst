  92   1               Delay_ms(400);
  93   1               LCD12864_Write_Cmd(0x0c,1); // 显示开及光标设置
  94   1               Delay_ms(400);
  95   1               LCD12864_Write_Cmd(0x08,1); //显示清屏
  96   1               Delay_ms(400);
  97   1      }
