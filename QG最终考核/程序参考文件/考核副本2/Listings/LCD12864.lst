  26          //写指令
  27          void LCD12864_Write_Cmd(unsigned char cmd,BuysC)
  28          {
  29   1              if (BuysC) LCD12864_Check_Status(); //根据需要检测忙 
  30   1              LCD12864_RS=0;//选择命令
  31   1              LCD12864_WR=0;//选择写
  32   1              LCD12864_DATAPORT=cmd;//准备命令
  33   1              Delay_10us(1);
  34   1              LCD12864_E=1;
  35   1              LCD12864_E=1;
  36   1              LCD12864_E=1;//使能脚E先上升沿写入
  37   1              LCD12864_E=0;//使能脚E后负跳变完成写入
  38   1      }
  39          
  40          //写数据
  41          void LCD12864_Write_Data(unsigned char dat)
  42          {
  43   1              LCD12864_Check_Status(); //检测忙
  44   1              LCD12864_RS=1;//选择数据
  45   1              LCD12864_WR=0;//选择写
  46   1              LCD12864_DATAPORT=dat;//准备数据
  47   1              Delay_10us(1);
  48   1              LCD12864_E=1;
  49   1              LCD12864_E=1;
  50   1              LCD12864_E=1;//使能脚E先上升沿写入
  51   1              LCD12864_E=0;//使能脚E后负跳变完成写入
  52   1      }
  53          
  54          //读状态
C51 COMPILER V9.54   LCD12864                                                              04/13/2026 15:53:34 PAGE 2   

  55          unsigned char LCD12864_Check_Status(void)
  56          {
  57   1               LCD12864_DATAPORT = 0xFF; 
  58   1               LCD12864_RS = 0;
  59   1               LCD12864_WR = 1; 
  60   1               LCD12864_E = 1;
  61   1               while (LCD12864_DATAPORT & Busy); //检测忙信号
  62   1               LCD12864_E = 0;
  63   1               return(LCD12864_DATAPORT);
  64   1      }
