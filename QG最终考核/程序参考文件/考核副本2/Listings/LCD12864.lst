 456   1              for(x=15;x<31;x++){                             //32行
 457   2                      LCD12864_Write_Cmd((0x80+x),1);//列地址
 458   2                      LCD12864_Write_Cmd((0x80+8+i),1);       //行地址，下半屏，即第三行地址0X88      
 459   2                      for(y=0;y<2;y++)
 460   2                      {
 461   3                              LCD12864_Write_Data(DData[tmp+y]);//读取数据写入LCD
 462   3                      }
 463   2                      tmp+=2;         
 464   2              }
 465   1              LCD12864_Write_Cmd(0x36,1);     //扩充功能设定
 466   1              LCD12864_Write_Cmd(0x30,1);
 467   1      }
