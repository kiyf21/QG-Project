 122          void LCD12864_Show_String(unsigned char x,unsigned char y,unsigned char *str)
 123          {
 124   1              if(y<=0)y=0;
 125   1              if(y>3)y=3;
 126   1              x&=0x0f;        //限制x,y不能大于显示范围
 127   1      
 128   1              switch(y)
 129   1              {
 130   2                      case 0: x|=0x80;break;//第1行地址+x的偏移
 131   2                      case 1: x|=0x90;break;//第2行地址+x的偏移
 132   2                      case 2: x|=0x88;break;//第3行地址+x的偏移
 133   2                      case 3: x|=0x98;break;//第4行地址+x的偏移
 134   2              }
 135   1              LCD12864_Write_Cmd(x,1);
 136   1              while(*str!='\0')
 137   1              {
 138   2                      LCD12864_Write_Data(*str);
 139   2                      str++;          
 140   2              }       
 141   1      } 
