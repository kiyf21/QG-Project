  79          //LCD写入位置，用于显示位置变化的字符
  80          void LCD12864_Set_Location(unsigned char x, unsigned char y)
  81          {
  82   1              unsigned char addr;                                                             //光标RAM地址
  83   1              
  84   1              switch (y)
  85   1              {
  86   2                      case 0: addr = 0x80 + x; break;         //设置光标在屏幕第一行x位置汉字位
  87   2                      case 1: addr = 0x90 + x; break;         //设置光标在屏幕第二行x位置汉字位
  88   2                      case 2: addr = 0x88 + x; break;         //设置光标在屏幕第三行x位置汉字位
  89   2                      case 3: addr = 0x98 + x; break;         //设置光标在屏幕第四行x位置汉字位
  90   2                      default: break;
  91   2              }
  92   1              LCD12864_Write_Cmd(addr,1);                             //将光标RAM地址作为指令写入液晶 
  93   1              Delay_10us(10);                                                 //延时
  94   1      }
