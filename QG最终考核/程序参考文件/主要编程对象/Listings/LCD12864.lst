  23          //写指令
  24          void LCD12864_Write_Cmd(unsigned char cmd,BuysC)
  25          {
  26   1              if (BuysC) LCD12864_Check_Status(); //根据需要检测忙 
  27   1              LCD12864_RS=0;//选择命令
  28   1              LCD12864_WR=0;//选择写
  29   1              LCD12864_DATAPORT=cmd;//准备命令
  30   1              Delay_10us(1);
  31   1              LCD12864_E=1;
  32   1              LCD12864_E=1;
  33   1              LCD12864_E=1;//使能脚E先上升沿写入
  34   1              LCD12864_E=0;//使能脚E后负跳变完成写入
  35   1      }
  36          
  37          //写数据
  38          void LCD12864_Write_Data(unsigned char dat)
  39          {
  40   1              LCD12864_Check_Status(); //检测忙
  41   1              LCD12864_RS=1;//选择数据
  42   1              LCD12864_WR=0;//选择写
  43   1              LCD12864_DATAPORT=dat;//准备数据
  44   1              Delay_10us(1);
  45   1              LCD12864_E=1;
  46   1              LCD12864_E=1;
  47   1              LCD12864_E=1;//使能脚E先上升沿写入
  48   1              LCD12864_E=0;//使能脚E后负跳变完成写入
  49   1      }
  50          
  51          //读状态
  52          unsigned char LCD12864_Check_Status(void)
  53          {
  54   1               LCD12864_DATAPORT = 0xFF; 
C51 COMPILER V9.54   LCD12864                                                              04/14/2026 16:26:11 PAGE 2   

  55   1               LCD12864_RS = 0;
  56   1               LCD12864_WR = 1; 
  57   1               LCD12864_E = 1;
  58   1               while (LCD12864_DATAPORT & Busy); //检测忙信号
  59   1               LCD12864_E = 0;
