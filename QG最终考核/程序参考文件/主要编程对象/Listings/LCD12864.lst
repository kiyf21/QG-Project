 165          //图形显示128*64
 166          void LCD12864_Show_Image (unsigned char code *DData)
 167          {
 168   1              unsigned char x,y,i;
 169   1              unsigned int tmp=0;
 170   1              
 171   1              LCD12864_Write_Cmd(0x34,1);  // 关闭绘图显示，进入指令模式
 172   1          LCD12864_Write_Cmd(0x36,1);  // 打开绘图模式
 173   1              
 174   1              for(i=0;i<9;){          //分两屏，上半屏和下半屏，因为起始地址不同，需要分开
 175   2                      for(x=0;x<32;x++){                              //32行
 176   3                              LCD12864_Write_Cmd((0x80+x),1);//列地址
 177   3                              LCD12864_Write_Cmd((0x80+i),1); //行地址，下半屏，即第三行地址0X88      
 178   3                              for(y=0;y<16;y++)
C51 COMPILER V9.54   LCD12864                                                              04/14/2026 16:26:11 PAGE 4   

 179   3                              {
 180   4                                      LCD12864_Write_Data(DData[tmp+y]);//读取数据写入LCD
 181   4                              }
 182   3                              tmp+=16;                
 183   3                      }
 184   2                      i+=8;
 185   2              }
 186   1              LCD12864_Write_Cmd(0x36,1);     //扩充功能设定
 187   1              LCD12864_Write_Cmd(0x30,1);
 188   1      }
