 199          // ====================== 菜单总运行 ======================
 200          void Menu_Run(void)
 201          {
 202   1          u8 key;
 203   1              u8 last_state = 0xFF; // 记录上一状态，用于自动刷新
 204   1          Show_MainMenu();
 205   1      
 206   1          while(1)
 207   1          {
 208   2                      if(now_state != last_state)
 209   2              {
 210   3                  last_state = now_state;
 211   3                  switch(now_state)
 212   3                  {
 213   4                      case MENU_MAIN:      Show_MainMenu();    break;
 214   4                      case MENU_GAME_INFO: Show_GameInfo();    break;
 215   4                      case MENU_LEVEL_SEL: Show_LevelSel();    break;
 216   4                      case GAME_PLAYING:   Show_GameStart();   break;
 217   4                                      case GAME_SETTLEMENT:Show_SettleMent();  break;
 218   4                                      case SAVE_CHECK:     Show_SaveScore();  break;
 219   4                  }
 220   3              }
 221   2              key = MatrixKey();
 222   2              if(key == 0) continue;
 223   2              switch(now_state)
 224   2              {
 225   3                  case MENU_MAIN:      MainMenu_Key(key);    break;
 226   3                  case MENU_GAME_INFO: GameInfo_Key(key);    break;
 227   3                  case MENU_LEVEL_SEL: LevelSel_Key(key);    break;
 228   3                  case GAME_PLAYING:   Game_Main();          break;
 229   3                              case GAME_SETTLEMENT:SettleMent_Key(key);  break;
 230   3                              case SAVE_CHECK:     GameInfo_Key(key);  break;
 231   3                              
 232   3              }
