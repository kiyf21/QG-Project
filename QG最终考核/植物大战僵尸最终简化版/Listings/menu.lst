 139          //菜单按钮控制
 140          static void MainMenu_Key(u8 key)
 141          {
 142   1          if(key == 2) // 上
 143   1          {
 144   2              if(main_sel > 0) main_sel--;
 145   2          }
 146   1          if(key == 10) // 下
 147   1          {
 148   2              if(main_sel < 2) main_sel++;
 149   2          }
 150   1          if(key == 6) // 确定
 151   1          {
 152   2              if(main_sel == 0) now_state = MENU_GAME_INFO;//状态切换为游戏简介
 153   2              if(main_sel == 1) now_state = MENU_LEVEL_SEL;//状态切换为难度选择
 154   2                      if(main_sel == 2) now_state = SAVE_CHECK;//状态切换为难度选择
 155   2          }
 156   1          Show_MainMenu();
 157   1      }
