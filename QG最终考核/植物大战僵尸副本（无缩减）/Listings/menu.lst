 118          // ====================== 菜单逻辑 ======================
 119          //菜单按钮控制
 120          static void MainMenu_Key(u8 key)
 121          {
 122   1          if(key == 2) // 上
 123   1          {
 124   2              if(main_sel > 0) main_sel--;
 125   2          }
 126   1          if(key == 10) // 下
 127   1          {
 128   2              if(main_sel < 2) main_sel++;
 129   2          }
 130   1          if(key == 6) // 确定
 131   1          {
 132   2              if(main_sel == 0) now_state = MENU_GAME_INFO;//状态切换为游戏简介
 133   2              if(main_sel == 1) now_state = MENU_LEVEL_SEL;//状态切换为难度选择
 134   2                      if(main_sel == 2) now_state = SAVE_CHECK;//状态切换为难度选择
 135   2          }
 136   1          Show_MainMenu();
 137   1      }
