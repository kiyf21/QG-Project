 158          //按键控制游标上下移动
 159          static void Chosen_Position(u8 key)
 160          {
 161   1          if(key == 2) // 上
 162   1          {
 163   2              if(Position/10!=1)
 164   2                      {
 165   3                              Last_Position = Position;
 166   3                              Position=Position-10;
 167   3                      }
 168   2                      Select_Plot(Last_Position,Position);
 169   2                      
 170   2          
 171   2              }
 172   1          if(key == 10) // 下
 173   1          {
 174   2              if(Position/10!=3)
 175   2                      {
 176   3                              Last_Position = Position;
 177   3                              Position=Position+10;
 178   3                      }
