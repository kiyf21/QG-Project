 182   1          {
 183   2              if(Position%10!=1)
 184   2                      {
 185   3                              Last_Position = Position;
 186   3                              Position=Position-1;
 187   3                      }
 188   2                      Select_Plot(Last_Position,Position);
 189   2          }
