 222          //选择植物类型按键
 223          static void Type_Plant_Key(u8 key)
 224          {
 225   1          if(key == 5)//左选
 226   1          {
 227   2              if(Type_Plant > 0) Type_Plant--;
 228   2                      switch(Type_Plant)
 229   2                      {
 230   3                              case 1:Show_Position(Position,IMG_DATA_Position); break;//1选择植物
 231   3                              case 0:Show_Position(Position,IMG_DATA2_Plant); break;//空置
