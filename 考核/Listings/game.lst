 233   3                      }
 234   2          }
 235   1          if(key == 7)//右选
 236   1          {
 237   2              if(Type_Plant < 2) Type_Plant++;
 238   2                      switch(Type_Plant)
 239   2                      {
 240   3                              case 1:Show_Position(Position,IMG_DATA_Position); break;
