  77          //图形显示122*32
  78          void DisplayImage (unsigned char code *DData)
  79          {
  80   1              unsigned char x,y,i;
  81   1              unsigned int tmp=0;
  82   1              
  83   1              lcd12864_write_cmd(0x34,1);  // 关闭绘图显示，进入指令模式
  84   1          lcd12864_write_cmd(0x36,1);  // 打开绘图模式
  85   1              
  86   1              for(i=0;i<9;){          //分两屏，上半屏和下半屏，因为起始地址不同，需要分开
  87   2              for(x=0;x<32;x++)
  88   2              {                               //32行
  89   3                      //lcd12864_write_cmd(0x34,1);
  90   3                      lcd12864_write_cmd((0x80+x),1);//列地址
