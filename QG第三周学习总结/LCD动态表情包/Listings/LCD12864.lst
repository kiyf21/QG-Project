  20          //写数据
  21          void lcd12864_write_data(unsigned char dat)
  22          {
  23   1              ReadStatusLCD(); //检测忙
  24   1              LCD12864_RS=1;//选择数据
  25   1              LCD12864_WR=0;//选择写
  26   1              LCD12864_DATAPORT=dat;//准备数据
  27   1              delay_10us(1);
  28   1              LCD12864_E=1;
  29   1              LCD12864_E=1;
  30   1              LCD12864_E=1;//使能脚E先上升沿写入
  31   1              LCD12864_E=0;//使能脚E后负跳变完成写入
  32   1      }
  33          
  34          //写指令
  35          void lcd12864_write_cmd(unsigned char cmd,BuysC)
  36          {
  37   1              if (BuysC) ReadStatusLCD(); //根据需要检测忙 
  38   1              LCD12864_RS=0;//选择命令
  39   1              LCD12864_WR=0;//选择写
  40   1              LCD12864_DATAPORT=cmd;//准备命令
  41   1              delay_10us(1);
  42   1              LCD12864_E=1;
  43   1              LCD12864_E=1;
  44   1              LCD12864_E=1;//使能脚E先上升沿写入
  45   1              LCD12864_E=0;//使能脚E后负跳变完成写入
  46   1      }
  47          
  48          //读状态
  49          unsigned char ReadStatusLCD(void)
  50          {
  51   1               LCD12864_DATAPORT = 0xFF; 
  52   1               LCD12864_RS = 0;
  53   1               LCD12864_WR = 1; 
  54   1               LCD12864_E = 1;
C51 COMPILER V9.54   LCD12864                                                              04/07/2026 20:07:26 PAGE 2   

  55   1               while (LCD12864_DATAPORT & Busy); //检测忙信号
