  92   3                      //lcd12864_write_cmd(0x30,1);           
  93   3                      for(y=0;y<16;y++)
  94   3                      {
  95   4                              lcd12864_write_data(DData[tmp+y]);//读取数据写入LCD
  96   4                              //delay_10us(1);
  97   4                      }
  98   3                      tmp+=16;                
  99   3              }
 100   2              i+=8;
 101   2              }
