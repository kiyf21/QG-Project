   1          #include <REGX52.H>
   2          /**
   3            * @brief  串口初始化 4800bps@12.000MHz
   4            * @param      无
   5            * @retval     无
   6            */
   7          void UART_Init()//4800bps@12.000MHz
   8          {
   9   1              SCON=0x50;
  10   1              PCON |= 0x80;
  11   1              //串口配置寄存器一
  12   1              TMOD &= 0x0F;           //设置定时器模式
  13   1              TMOD |= 0x20;           //设置定时器模式
