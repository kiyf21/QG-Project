  15   1              TH1 = 0xF4;             //设置定时初值            单片机不同从0xF3改到0xF4
  16   1              ET1 = 0;                //禁止定时器1中断
  17   1              TR1 = 1;                //启动定时器1
  18   1              EA=1;
  19   1              ES=1;
  20   1      }
  21          /**
