  23            * @param      Byte 要发送的一个字节数据
  24            * @retval     无
  25            */
  26          
  27          void UART_SendByte(unsigned char Byte)
  28          {
  29   1              SBUF=Byte;
  30   1              while(TI==0);
  31   1              TI=0;
  32   1      }


